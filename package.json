{
    "name": "@hlw-uni/mp-vue",
    "version": "2.1.12",
    "description": "hlw-uni 小程序运行时 — Vue 组件 + composables + theme + http + 工具集（合并自原 mp-core）",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./dist/*": "./dist/*",
        "./src/*": "./src/*"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "publish:npm": "pnpm build && npm publish --access public"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "pinia": ">=2.0.0",
        "vue": ">=3.4.0"
    },
    "devDependencies": {
        "@dcloudio/types": "^3.4.30",
        "@types/md5": "^2.3.6",
        "@types/node": "^20.19.39",
        "@vitejs/plugin-vue": "^5.2.4",
        "pinia": "^2.3.1",
        "typescript": "^4.9.5",
        "vite": "5.2.8",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.5.32"
    },
    "dependencies": {
        "md5": "^2.3.0",
        "z-paging": "^2.8.8"
    }
}
