{
    "name": "@hlw-uni/mp-vue",
    "version": "1.0.32",
    "description": "hlw-uni Vue 组件库 — 供小程序业务方使用的 UI 组件集合",
    "main": "src/index.ts",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "require": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./src/*": "./src/*"
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "publish:npm": "pnpm build && npm publish --access public"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "vue": ">=3.4.0",
        "pinia": ">=2.0.0"
    },
    "devDependencies": {
        "@dcloudio/types": "^3.4.8",
        "@types/node": "^20.11.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "typescript": "^4.9.4",
        "vite": "5.2.8",
        "vite-plugin-dts": "^4.5.4",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@hlw-uni/mp-core": "^1.0.10"
    }
}
